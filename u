                    FogCache[obj] = {enabled = obj:IsA("Atmosphere") or true, parent = obj.Parent}
                end
                if obj:IsA("Atmosphere") then
                    obj.Density = 0
                else
                    obj.Parent = nil
                end
            end
        end
        
        lighting.FogEnd = 100000
        lighting.FogStart = 0
    end)
